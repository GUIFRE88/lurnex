<div class="container py-4">
  <h1>Courses</h1>
  <div class="mb-3 d-flex gap-2">
    <%= link_to "New course", new_admin_course_path, class: "btn btn-primary" %>
    <%= link_to "Back to admin dashboard", admin_dashboard_path, class: "btn btn-outline-secondary" %>
  </div>

  <% if flash[:alert] %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>
  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>

  <% @courses.each do |course| %>
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5"><%= course.title %></h2>
        <p><%= course.description %></p>
        <%= form_with url: admin_enrollments_path, method: :post, class: "row g-2" do |f| %>
          <%= hidden_field_tag :course_id, course.id %>
          <div class="col-md-8">
            <%= select_tag :membership_id, options_from_collection_for_select(@students, :id, :id), class: "form-select", include_blank: "Select student membership id" %>
          </div>
          <div class="col-md-4">
            <%= f.submit "Enroll student", class: "btn btn-outline-primary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
