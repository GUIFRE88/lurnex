<div class="container py-4">
  <h1>Admin Dashboard</h1>
  <p>Organization: <strong><%= @organization.name %></strong></p>
  <% if current_user.memberships.count > 1 %>
    <%= form_with url: switch_organization_path, method: :patch, class: "mb-3" do %>
      <div class="input-group" style="max-width: 420px;">
        <%= select_tag :organization_id, options_from_collection_for_select(current_user.organizations, :id, :name, current_organization.id), class: "form-select" %>
        <button class="btn btn-outline-secondary" type="submit">Switch</button>
      </div>
    <% end %>
  <% end %>

  <div class="row g-3 mt-1">
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h2 class="h5">Courses</h2>
          <p class="mb-0"><%= @courses_count %></p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h2 class="h5">Students</h2>
          <p class="mb-0"><%= @students_count %></p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h2 class="h5">Completed enrollments</h2>
          <p class="mb-0"><%= @completed_count %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 d-flex gap-2">
    <%= link_to "Manage courses", admin_courses_path, class: "btn btn-primary" %>
    <%= link_to "Manage invites", admin_invites_path, class: "btn btn-outline-primary" %>
    <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-outline-danger" %>
  </div>
</div>
